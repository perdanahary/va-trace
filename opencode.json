{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "plane": {
      "type": "local",
      "command": [
        "uvx",
        "plane-mcp-server",
        "stdio"
      ],
      "enabled": true,
      "environment": {
        "PLANE_API_KEY": "plane_api_620935da55b9452d95efa615b5568f50",
        "PLANE_WORKSPACE_SLUG": "officebee",
        "PLANE_BASE_URL": "https://pm.obdev.my.id/"
      }
    },
    "figma": {
      "type": "remote",
      "url": "https://mcp.figma.com/mcp",
      "enabled": true
    },
    "figma-console": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "figma-console-mcp@latest"
      ],
      "enabled": true,
      "environment": {
        "FIGMA_ACCESS_TOKEN": "FIGMA_TOKEN_REMOVED",
        "ENABLE_MCP_APPS": "true"
      }
    },
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp",
        "--path",
        "."
      ],
      "enabled": true
    },
    "jam": {
      "type": "remote",
      "url": "https://mcp.jam.dev/mcp"
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp"
      ],
      "enabled": true
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest"
  ]
}